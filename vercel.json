{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "server/src/**"
    }
  },
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
